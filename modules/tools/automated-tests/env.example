# Copy to .env and fill in. Used by cognite_sdk_config.yaml.
CDF_PROJECT=your-cdf-project
CDF_URL=https://api.cognite.com
IDP_TOKEN_URL=https://login.microsoftonline.com/YOUR_TENANT/oauth2/v2.0/token
IDP_CLIENT_ID=your-client-id
IDP_CLIENT_SECRET=your-client-secret
IDP_SCOPES=https://api.cognitedata.com/.default

# Optional: alert when scheduled test runs fail (Slack and/or Teams). Do not commit webhook URLs.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
