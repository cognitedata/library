{
    "version": "0.1.0",
    "configurations": [
      {
        "name": "Flows | File Annotation Dashboard: Local Mode",
        "type": "chrome",
        "request": "launch",
        "url": "https://localhost:3001",
        "webRoot": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/flows/file_annotation_dashboard",
        "preLaunchTask": "file-annotation: start local stack (flows)",
        "env": {
          "VITE_RUNTIME_MODE": "cdf_local"
        },
        "sourceMaps": true,
        "timeout": 50000,
      },
      {
        "name": "Flows | File Annotation Dashboard: Host Mode",
        "type": "node-terminal",
        "request": "launch",
        "command": "npm start",
        "cwd": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/flows/file_annotation_dashboard",
        "env": {
          "VITE_RUNTIME_MODE": "cdf_host"
        },
      },
      {
        "name": "Flows | File Annotation Dashboard: Mock Mode",
        "type": "node-terminal",
        "request": "launch",
        "command": "npm start",
        "cwd": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/flows/file_annotation_dashboard",
        "env": {
          "VITE_RUNTIME_MODE": "mock"
        }
      },      
      {
        "name": "Streamlit | Annotation Quality Dashboard",
        "type": "debugpy",
        "request": "launch",
        "module": "streamlit",
        "cwd": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/streamlit/file_annotation_dashboard_annotation_quality",
        "console": "integratedTerminal",
        "args": [
          "run",
          "Annotation_Quality.py"
        ]
      },
      {
        "name": "Streamlit | Pipeline Health Dashboard",
        "type": "debugpy",
        "request": "launch",
        "module": "streamlit",
        "cwd": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/streamlit/file_annotation_dashboard_pipeline_health",
        "console": "integratedTerminal",
        "args": [
          "run",
          "Pipeline_Health.py"
        ]
      },
      {
        "name": "Prepare Handler",
        "type": "debugpy",
        "request": "launch",
        "program": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/functions/fn_file_annotation_prepare/handler.py",
        "console": "integratedTerminal",
        "args": [
          "ep_file_annotation",
          "DEBUG", //ensure that this adheres to -> log_level: Literal["DEBUG", "INFO", "WARNING", "ERROR"]
          "annotation_logs/launch_thread_1.log"
        ]
      },
      {
        "name": "Launch Handler",
        "type": "debugpy",
        "request": "launch",
        "program": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/functions/fn_file_annotation_launch/handler.py",
        "console": "integratedTerminal",
        "args": [
          "ep_file_annotation",
          "DEBUG", //ensure that this adheres to -> log_level: Literal["DEBUG", "INFO", "WARNING", "ERROR"]
          "annotation_logs/launch_thread_1.log"
        ]
      },
      {
        "name": "Finalize Handler - Single Thread",
        "type": "debugpy",
        "request": "launch",
        "program": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/functions/fn_file_annotation_finalize/handler.py",
        "console": "integratedTerminal",
        "args": [
          "ep_file_annotation",
          "DEBUG", //ensure that this adheres to -> log_level: Literal["DEBUG", "INFO", "WARNING", "ERROR"]
          "Singular",
          "annotation_logs/finalize_thread_1.log",
        ]
      },
      {
        "name": "Finalize Handler - Multiple Threads",
        "type": "debugpy",
        "request": "launch",
        "program": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/functions/fn_file_annotation_finalize/handler.py",
        "console": "integratedTerminal",
        "args": [
          "ep_file_annotation",
          "DEBUG", //ensure that this adheres to -> log_level: Literal["DEBUG", "INFO", "WARNING", "ERROR"]
          "Parallel",
          "annotation_logs/finalize_thread_1.log",
          "annotation_logs/finalize_thread_2.log",
          "annotation_logs/finalize_thread_3.log",
          "annotation_logs/finalize_thread_4.log"
        ]
      },
      {
        "name": "Promote Handler",
        "type": "debugpy",
        "request": "launch",
        "program": "<insert>/modules/accelerators/contextualization/cdf_file_annotation/functions/fn_file_annotation_promote/handler.py",
        "console": "integratedTerminal",
        "args": [
          "ep_file_annotation",
          "DEBUG", //ensure that this adheres to -> log_level: Literal["DEBUG", "INFO", "WARNING", "ERROR"]
          "annotation_logs/promote_thread_1.log"
        ]
      }
    ]
  }